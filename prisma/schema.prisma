// Chalet Aletsch — domain schema
// Phase 1 scaffolding. Models declared but not yet wired to UI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// PROPERTY & INVENTORY
// =============================================================================

model Property {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  taglineDe   String?
  taglineEn   String?
  street      String
  zip         String
  city        String
  country     String   @default("CH")
  email       String
  phone       String
  iban        String?
  vatNumber   String?
  uid         String?
  rooms       RoomType[]
  experiences Experience[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RoomType {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  slug        String   @unique
  nameDe      String
  nameEn      String
  subtitleDe  String?
  subtitleEn  String?
  descriptionDe String? @db.Text
  descriptionEn String? @db.Text
  capacity    Int
  basePrice   Decimal  @db.Decimal(10, 2)
  areaSqm     Int?
  rooms       Room[]
  photos      String[] // Cloudinary public IDs
  position    Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Room {
  id          String     @id @default(cuid())
  roomTypeId  String
  roomType    RoomType   @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  number      String     // e.g. "101"
  notes       String?
  bookings    BookingItem[]
  blocked     BlockedDate[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([roomTypeId, number])
}

// =============================================================================
// BOOKINGS
// =============================================================================

enum BookingStatus {
  pending_payment
  confirmed
  checked_in
  checked_out
  cancelled
  no_show
}

model Booking {
  id           String         @id @default(cuid())
  reference    String         @unique // e.g. CA-2026-0001
  userId       String?
  user         User?          @relation(fields: [userId], references: [id])
  guestEmail   String         // captured at booking time
  guestName    String
  locale       String         @default("de")
  checkIn      DateTime       @db.Date
  checkOut     DateTime       @db.Date
  adults       Int            @default(1)
  children     Int            @default(0)
  status       BookingStatus  @default(pending_payment)
  subtotal     Decimal        @db.Decimal(10, 2)
  taxAmount    Decimal        @default(0) @db.Decimal(10, 2)
  total        Decimal        @db.Decimal(10, 2)
  depositAmount Decimal       @default(0) @db.Decimal(10, 2)
  notes        String?        @db.Text
  internalNotes String?       @db.Text
  items        BookingItem[]
  extras       BookingExtra[]
  payments     Payment[]
  reviews      Review[]
  holdExpiresAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model BookingItem {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  unitPrice Decimal  @db.Decimal(10, 2)
  nights    Int
  lineTotal Decimal  @db.Decimal(10, 2)

  @@index([bookingId])
}

// =============================================================================
// GUESTS (auth-linked)
// =============================================================================

enum UserRole {
  guest
  staff
  admin
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  emailVerified      DateTime?
  name               String?
  image              String?
  preferredLocale    String    @default("de")
  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime?
  role               UserRole  @default(guest)
  bookings           Booking[]
  reviews            Review[]
  accounts           Account[]
  sessions           Session[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// =============================================================================
// PAYMENTS
// =============================================================================

enum PaymentType {
  deposit
  balance
  full
  refund
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("CHF")
  type            PaymentType
  status          PaymentStatus @default(pending)
  stripeIntentId  String?       @unique
  stripeChargeId  String?
  method          String?       // "card" | "twint" | "bank_transfer"
  receivedAt      DateTime?
  reference       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([bookingId])
}

// =============================================================================
// EXTRAS / EXPERIENCES
// =============================================================================

model Experience {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  slug        String   @unique
  nameDe      String
  nameEn      String
  descriptionDe String? @db.Text
  descriptionEn String? @db.Text
  unitPrice   Decimal  @db.Decimal(10, 2)
  unit        String   @default("piece") // piece | hour | person | day
  bookingExtras BookingExtra[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BookingExtra {
  id           String     @id @default(cuid())
  bookingId    String
  booking      Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id])
  quantity     Int        @default(1)
  unitPrice    Decimal    @db.Decimal(10, 2)
  lineTotal    Decimal    @db.Decimal(10, 2)
  notes        String?

  @@index([bookingId])
}

// =============================================================================
// PRICING & AVAILABILITY
// =============================================================================

model PricingRule {
  id          String   @id @default(cuid())
  name        String
  dateFrom    DateTime @db.Date
  dateTo      DateTime @db.Date
  multiplier  Decimal  @default(1) @db.Decimal(5, 2)
  flatAdjust  Decimal? @db.Decimal(10, 2)
  minStay     Int?
  priority    Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlockedDate {
  id        String   @id @default(cuid())
  roomId    String?
  room      Room?    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  dateFrom  DateTime @db.Date
  dateTo    DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  @@index([roomId, dateFrom, dateTo])
}

// =============================================================================
// REVIEWS, NEWSLETTER, CONTACT, CHAT
// =============================================================================

model Review {
  id         String   @id @default(cuid())
  bookingId  String?
  booking    Booking? @relation(fields: [bookingId], references: [id])
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  authorName String
  rating     Int      // 1..5
  body       String   @db.Text
  locale     String   @default("de")
  approved   Boolean  @default(false)
  publishedAt DateTime?
  source     String   @default("internal") // internal | google
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model NewsletterSubscriber {
  id          String    @id @default(cuid())
  email       String    @unique
  locale      String    @default("de")
  consentAt   DateTime  @default(now())
  unsubscribedAt DateTime?
  source      String?
  createdAt   DateTime  @default(now())
}

enum ContactStatus {
  open
  in_progress
  answered
  closed
}

model ContactRequest {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String        @db.Text
  locale    String        @default("de")
  status    ContactStatus @default(open)
  ipAddress String?
  userAgent String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ChatSession {
  id        String    @id @default(cuid())
  sessionId String    @unique
  locale    String    @default("de")
  messages  Json
  ipAddress String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// =============================================================================
// SETTINGS
// =============================================================================

model AppSetting {
  key       String   @id
  value     String   @db.Text
  category  String?
  updatedAt DateTime @updatedAt
}

// =============================================================================
// AUTH (Auth.js v5 — wired in next phase)
// =============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
